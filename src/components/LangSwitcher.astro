---
import {
	ui,
	defaultLocale,
	routeEquivalents,
	type Locale,
} from "../i18n/site";

interface Props {
	locale?: Locale;
	variant?: "light" | "dark";
}

const { locale = defaultLocale, variant = "light" } = Astro.props;
const t = ui[locale];
const targetLocale = locale === "en" ? "pt" : "en";
const currentPath = Astro.url.pathname;

const switchLangHref = routeEquivalents[currentPath] ?? t.switchLangHref;
---

<div class:list={["lang-switcher", { "lang-switcher--dark": variant === "dark" }]}>
	<span class="lang-current">{locale.toUpperCase()}</span>
	<span class="lang-sep">/</span>
	<a
		href={switchLangHref}
		aria-label={t.switchLangAriaLabel}
		data-lang-switch
		data-locale={targetLocale}
	>{t.switchLang}</a>
</div>

<style>
	.lang-switcher {
		display: flex;
		align-items: center;
		gap: 0.3em;
		font-size: 0.875rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.lang-current {
		color: var(--color-ink);
		font-weight: 600;
	}

	.lang-sep {
		color: var(--color-ink);
		opacity: 0.4;
	}

	a {
		color: var(--color-ink);
		text-decoration: none;
		opacity: 0.4;
		transition: color 150ms ease, opacity 150ms ease;
	}

	a:hover,
	a:focus-visible {
		color: var(--color-contrast);
		opacity: 1;
		text-decoration: none;
	}

	.lang-switcher--dark .lang-current,
	.lang-switcher--dark .lang-sep,
	.lang-switcher--dark a {
		color: var(--color-base);
	}
</style>
