---
import { getEntry } from "astro:content";
import { Image } from "astro:assets";
import { defaultLocale, type Locale } from "../../i18n/site";
import HeroBackground from "../HeroBackground.astro";
import BookingForm from "../BookingForm.astro";
import headshot from "../../assets/images/headshot.jpg";

const locale = (Astro.currentLocale ?? defaultLocale) as Locale;
const entry = await getEntry("about", locale);
const content = entry!.data;
---

<section
	class="relative flex min-h-[40vh] w-full items-center overflow-hidden pt-[calc(var(--spacing-section)*2)] pb-[calc(var(--spacing-section)*1.25)]"
>
	<HeroBackground orb1="var(--color-purple)" orb3="var(--color-blue)" />
	<div
		class="relative z-2 mx-auto w-full max-w-(--width-content) px-(--spacing-outer) text-center"
	>
		<h1 class="font-serif text-5xl md:text-7xl tracking-[-0.04em]">
			{content.hero.heading}
		</h1>
	</div>
</section>

<section class="py-(--spacing-section)">
	<div class="mx-auto max-w-(--width-wide) px-(--spacing-outer)">
		<div class="bio-grid">
			<div class="bio-image">
				<Image src={headshot} alt="Fábio Barbosa" class="bio-photo" />
			</div>
			<div class="bio-text">
				{
					content.bio.paragraphs.map((p) => (
						<p class="mb-4 last:mb-0" set:html={p} />
					))
				}
			</div>
		</div>
	</div>
</section>

<BookingForm locale={locale} />

<style>
	.bio-grid {
		display: grid;
		grid-template-columns: 1fr 2fr;
		gap: 4rem;
		align-items: start;
	}

	@media (max-width: 768px) {
		.bio-grid {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
	}

	.bio-photo {
		width: 100%;
		height: auto;
		border-radius: 4px;
		background-color: var(--color-overlay);
	}
</style>
