---
import { getEntry } from "astro:content";
import { defaultLocale, type Locale, ui } from "../../i18n/site";
import BookingForm from "../BookingForm.astro";
import HeroBackground from "../HeroBackground.astro";

import chartRings from "../../assets/images/chart-rings.svg?raw";
import chartSpokes from "../../assets/images/chart-spokes.svg?raw";
import chartTicks from "../../assets/images/chart-ticks.svg?raw";

const locale = (Astro.currentLocale ?? defaultLocale) as Locale;
const entry = await getEntry("home", locale);
const content = entry!.data;
const { bookCta, learnMore, aboutCta, aboutCtaHref } = ui[locale];
---

<HeroBackground
	orb1="var(--color-blue)"
	orb2="var(--color-orange-light)"
	orb3="var(--color-amber)"
/>

<section
	id="hero-section"
	class="relative w-full min-h-[95vh] flex items-center pt-[calc(var(--spacing-section)*2)] pb-[calc(var(--spacing-section)*2)] overflow-hidden"
>
	<div class="hero-circles" aria-hidden="true">
		<div class="circles-stack">
			<div id="circle-rings" class="circle-layer" set:html={chartRings} />
			<div id="circle-spokes" class="circle-layer" set:html={chartSpokes} />
			<div id="circle-ticks" class="circle-layer" set:html={chartTicks} />
		</div>
	</div>

	<div id="scroll-arrow" aria-hidden="true">
		<svg
			width="20"
			height="32"
			viewBox="0 0 20 32"
			fill="none"
			stroke="currentColor"
			stroke-width="1"
			stroke-linecap="round"
			stroke-linejoin="round"
		>
			<line x1="10" y1="0" x2="10" y2="22"></line>
			<polyline points="2,14 10,24 18,14"></polyline>
		</svg>
	</div>

	<div
		class="relative z-2 w-full max-w-(--width-content) mx-auto px-(--spacing-outer) text-center"
	>
		<h1
			class="text-7xl max-md:text-5xl font-serif tracking-tight leading-none mb-6"
		>
			{
				content.hero.heading.map((line, i) => (
					<>
						{line}
						{i < content.hero.heading.length - 1 && <br />}
					</>
				))
			}
		</h1>
		<p class="text-xl md:text-2xl">
			{content.hero.subheading}
		</p>
		<div class="flex max-md:flex-col gap-4 items-center justify-center mt-8">
			<a href={content.hero.ctaHref} class="button">{bookCta}</a>
			<a href={content.hero.ctaSecondaryHref} class="button button-alt"
				>{learnMore}</a
			>
		</div>
	</div>
</section>

<section class="flex items-center py-(--spacing-section)">
	<div class="max-w-(--width-wide) mx-auto px-(--spacing-outer)">
		<div class="bio-grid">
			<div class="bio-image">
				<img src="/images/fabio.jpg" alt="Fábio Barbosa" class="bio-photo" />
			</div>
			<div class="bio-text">
				{
					content.intro.paragraphs.map((p) => (
						<p class="mb-4 last:mb-0" set:html={p} />
					))
				}
				<a href={aboutCtaHref} class="button mt-6">{aboutCta}</a>
			</div>
		</div>
	</div>
</section>

<BookingForm />

<script>
	const rings = document.getElementById("circle-rings") as HTMLImageElement;
	const spokes = document.getElementById("circle-spokes") as HTMLImageElement;
	const ticks = document.getElementById("circle-ticks") as HTMLImageElement;
	const arrow = document.getElementById("scroll-arrow") as HTMLElement;

	// Starting offsets (% of the element's own size)
	const START = {
		rings: { x: -67, y: 0, r: 0 },
		spokes: { x: 0, y: 0, r: 0 },
		ticks: { x: 67, y: 0, r: 0 },
	};

	function lerp(a: number, b: number, t: number) {
		return a + (b - a) * t;
	}

	function easeOut(t: number) {
		return 1 - Math.pow(1 - t, 3);
	}

	function updateCircles() {
		// Complete the animation once the user has scrolled 65% of the viewport height
		const raw = window.scrollY / (window.innerHeight * 0.35);
		const p = easeOut(Math.max(0, Math.min(1, raw)));

		rings.style.transform = `translate(${lerp(START.rings.x, 0, p)}%, ${lerp(START.rings.y, 0, p)}%) rotate(${lerp(START.rings.r, 0, p)}deg)`;
		spokes.style.transform = `translate(${lerp(START.spokes.x, 0, p)}%, ${lerp(START.spokes.y, 0, p)}%) rotate(${lerp(START.spokes.r, 0, p)}deg)`;
		ticks.style.transform = `translate(${lerp(START.ticks.x, 0, p)}%, ${lerp(START.ticks.y, 0, p)}%) rotate(${lerp(START.ticks.r, 0, p)}deg)`;

		// Fade arrow over the first 25% of viewport height scrolled
		arrow.style.opacity = String(
			Math.max(0, 1 - window.scrollY / (window.innerHeight * 0.25)),
		);
	}

	window.addEventListener("scroll", updateCircles, { passive: true });
	updateCircles();
</script>

<style>
	.hero-circles {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 1;
	}

	/* Centered anchor for all three layers */
	.circles-stack {
		position: absolute;
		top: 50%;
		left: 50%;
		translate: -50% -50%;
		width: min(90vw, 80vh);
		height: min(90vw, 80vh);
	}

	.circle-layer {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		opacity: 0.75;
		filter: saturate(0.55);
		will-change: transform;
	}

	.circle-layer :global(svg) {
		width: 100%;
		height: 100%;
		display: block;
	}

	#scroll-arrow {
		position: absolute;
		bottom: 2.5rem;
		left: 50%;
		translate: -50% 0;
		color: var(--color-accent);
		pointer-events: none;
		will-change: opacity;
	}

	#scroll-arrow svg {
		display: block;
		animation: arrow-blink 2.5s ease-in-out infinite;
	}

	@keyframes arrow-blink {
		0%,
		100% {
			opacity: 0.8;
		}
		50% {
			opacity: 0.1;
		}
	}

	/* Initial positions — JS will take over on scroll */
	#circle-rings {
		transform: translate(-67%, 0%);
	}
	#circle-spokes {
		transform: translate(0%, 0%);
	}
	#circle-ticks {
		transform: translate(67%, 0%);
	}

	/* Bio section */
	.bio-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: start;
	}

	@media (max-width: 768px) {
		.bio-grid {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
	}

	.bio-photo {
		width: 100%;
		aspect-ratio: 1 / 1;
		object-fit: cover;
		border-radius: 4px;
		background-color: var(--color-overlay);
	}
</style>
