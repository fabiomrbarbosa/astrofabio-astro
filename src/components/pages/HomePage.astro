---
import type { HomeContent } from "../../i18n";

interface Props {
	content: HomeContent;
}

const { content } = Astro.props;
---

<section
	id="hero-section"
	class="bg-contrast relative -mx-(--spacing-outer) min-h-screen flex items-center py-(--spacing-section) overflow-hidden"
>
	<div class="hero-circles" aria-hidden="true">
		<div class="circles-stack">
			<img
				src="/images/chart-rings.svg"
				class="circle-layer"
				id="circle-rings"
				alt=""
			/>
			<img
				src="/images/chart-spokes.svg"
				class="circle-layer"
				id="circle-spokes"
				alt=""
			/>
			<img
				src="/images/chart-ticks.svg"
				class="circle-layer"
				id="circle-ticks"
				alt=""
			/>
		</div>
	</div>

	<div id="scroll-arrow" aria-hidden="true">
		<svg width="20" height="32" viewBox="0 0 20 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
			<line x1="10" y1="0" x2="10" y2="20"/>
			<polyline points="2,14 10,24 18,14"/>
		</svg>
	</div>

	<div
		class="relative w-full max-w-(--width-content) mx-auto px-(--spacing-outer) text-center text-white"
	>
		<h1 class="text-7xl max-md:text-6xl font-serif leading-none mb-6">
			{
				content.hero.heading.map((line, i) => (
					<>
						{line}
						{i < content.hero.heading.length - 1 && <br />}
					</>
				))
			}
		</h1>
		<p class="text-2xl max-md:text-xl leading-tight">
			{content.hero.subheading}
		</p>
		<div class="flex gap-4 justify-center mt-8">
			<a href={content.hero.ctaHref} class="button">{content.hero.cta}</a>
			<a href={content.hero.ctaSecondaryHref} class="button button-alt-dark"
				>{content.hero.ctaSecondary}</a
			>
		</div>
	</div>
</section>

<section
	class="bg-contrast relative -mx-(--spacing-outer) flex items-center py-8"
>
	<div
		class="relative w-full max-w-(--width-content) mx-auto px-(--spacing-outer) text-center text-white"
	>
		{content.intro.paragraphs.map((p) => <p class="mb-6 last:mb-0">{p}</p>)}
	</div>
</section>

<script>
	const rings  = document.getElementById("circle-rings")  as HTMLImageElement;
	const spokes = document.getElementById("circle-spokes") as HTMLImageElement;
	const ticks  = document.getElementById("circle-ticks")  as HTMLImageElement;
	const arrow  = document.getElementById("scroll-arrow")  as HTMLElement;

	// Starting offsets (% of the element's own size)
	const START = {
		rings: { x: -67, y: 0, r: 0 },
		spokes: { x: 0, y: 0, r: 0 },
		ticks: { x: 67, y: 0, r: 0 },
	};

	function lerp(a: number, b: number, t: number) {
		return a + (b - a) * t;
	}

	function easeOut(t: number) {
		return 1 - Math.pow(1 - t, 3);
	}

	function updateCircles() {
		// Complete the animation once the user has scrolled 65% of the viewport height
		const raw = window.scrollY / (window.innerHeight * 0.35);
		const p = easeOut(Math.max(0, Math.min(1, raw)));

		rings.style.transform = `translate(${lerp(START.rings.x, 0, p)}%, ${lerp(START.rings.y, 0, p)}%) rotate(${lerp(START.rings.r, 0, p)}deg)`;
		spokes.style.transform = `translate(${lerp(START.spokes.x, 0, p)}%, ${lerp(START.spokes.y, 0, p)}%) rotate(${lerp(START.spokes.r, 0, p)}deg)`;
		ticks.style.transform = `translate(${lerp(START.ticks.x, 0, p)}%, ${lerp(START.ticks.y, 0, p)}%) rotate(${lerp(START.ticks.r, 0, p)}deg)`;

		// Fade arrow over the first 25% of viewport height scrolled
		arrow.style.opacity = String(Math.max(0, 1 - window.scrollY / (window.innerHeight * 0.25)));
	}

	window.addEventListener("scroll", updateCircles, { passive: true });
	updateCircles();
</script>

<style>
	.hero-circles {
		position: absolute;
		inset: 0;
		pointer-events: none;
		overflow: hidden;
	}

	/* Centered anchor for all three layers */
	.circles-stack {
		position: absolute;
		top: 50%;
		left: 50%;
		translate: -50% -50%;
		width: min(90vw, 80vh);
		height: min(90vw, 80vh);
	}

	.circle-layer {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		opacity: 0.1;
		filter: invert(1);
		will-change: transform;
	}

	#scroll-arrow {
		position: absolute;
		bottom: 2.5rem;
		left: 50%;
		translate: -50% 0;
		color: white;
		pointer-events: none;
		will-change: opacity;
	}

	#scroll-arrow svg {
		display: block;
		animation: arrow-blink 2.5s ease-in-out infinite;
	}

	@keyframes arrow-blink {
		0%, 100% { opacity: 0.8; }
		50%       { opacity: 0.1; }
	}

	/* Initial positions — JS will take over on scroll */
	#circle-rings {
		transform: translate(-67%, 0%);
	}
	#circle-spokes {
		transform: translate(0%, 0%);
	}
	#circle-ticks {
		transform: translate(67%, 0%);
	}
</style>
