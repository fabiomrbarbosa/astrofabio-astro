---
import { getEntry } from "astro:content";
import { defaultLocale, type Locale, ui } from "../../i18n/site";

import iconNatal from "../../assets/icons/icon-natal.svg?raw";
import iconNatalSolarReturn from "../../assets/icons/icon-natal-solar-return.svg?raw";
import iconHorary from "../../assets/icons/icon-horary.svg?raw";
import iconElective from "../../assets/icons/icon-elective.svg?raw";
import iconSynastry from "../../assets/icons/icon-synastry.svg?raw";
import BookingForm from "../BookingForm.astro";
import HeroBackground from "../HeroBackground.astro";

const icons: Record<string, string> = {
	natal: iconNatal,
	natalsolarreturn: iconNatalSolarReturn,
	horary: iconHorary,
	elective: iconElective,
	synastry: iconSynastry,
};

const locale = (Astro.currentLocale ?? defaultLocale) as Locale;
const entry = await getEntry("consultations", locale);
const content = entry!.data;
const { bookCta, learnMore, durationLabel, feeLabel } = ui[locale];
---

<section
	class="relative flex min-h-[70vh] w-full items-center overflow-hidden pt-[calc(var(--spacing-section)*2)] pb-[calc(var(--spacing-section)*1.25)]"
>
	<HeroBackground
		orb1="var(--color-amber)"
		orb2="var(--color-orange-light)"
		flip
	/>
	<div class="relative z-2 mx-auto w-full px-(--spacing-outer) text-center">
		<h1 class="mb-6 font-serif text-5xl md:text-7xl tracking-[-0.04em]">
			{content.hero.heading}
		</h1>
		<p class="text-xl max-w-2xl mx-auto">
			{content.hero.lead}
		</p>
		<div class="mt-8 flex items-center justify-center gap-4 max-md:flex-col">
			<a href="#book" class="button">{bookCta}</a>
			<a href="#cards-track" class="button button-alt">{learnMore}</a>
		</div>
	</div>
</section>

<div
	id="cards-track"
	class="cards-track mx-auto max-w-(--width-wide) px-(--spacing-outer)"
>
	{
		content.types.map((type, i) => (
			<article
				class:list={["card rounded-2xl", { "card--highlight": type.highlight }]}
				style={{ "--i": i }}
			>
				<div class="card-header">
					<div class="card-heading">
						{type.discipline && (
							<p class="text-accent mb-2 text-xs font-semibold tracking-widest uppercase">
								{type.discipline}
							</p>
						)}
						<h2 class="card-title mb-2 text-4xl font-serif tracking-tight">
							{type.title}
						</h2>
						<p class="font-semibold text-ink">
							{durationLabel}
							{type.duration}
						</p>
						<p class="mb-6 font-semibold text-ink">
							{feeLabel}
							{type.price}€
						</p>
					</div>

					<div class="card-icon" aria-hidden="true" set:html={icons[type.id]} />
				</div>

				<div class="card-content">
					<div class="card-body">
						{type.paragraphs.map((p) => (
							<p set:html={p} />
						))}
					</div>{" "}
					<a href="#book" data-type={type.id} class="button mt-8 inline-block">
						{bookCta}
					</a>
				</div>
			</article>
		))
	}
</div>

<script>
	document
		.querySelectorAll<HTMLAnchorElement>("a[data-type]")
		.forEach((link) => {
			link.addEventListener("click", () => {
				const typeSelect = document.getElementById(
					"cf-type",
				) as HTMLSelectElement | null;
				if (!typeSelect) return;
				typeSelect.value = link.dataset.type!;
				typeSelect.dispatchEvent(new Event("change"));
			});
		});

	document.addEventListener("DOMContentLoaded", () => {
		const cards = document.querySelectorAll<HTMLElement>(".card");

		const updateCards = () => {
			if (window.innerWidth <= 641) return;

			// Match margin-bottom: 7.5vh — ensures only one card transitions at a time
			const transitionRange = window.innerHeight * 0.075;

			cards.forEach((card, index) => {
				let depth = 0;

				for (let j = index + 1; j < cards.length; j++) {
					const above = cards[j] as HTMLElement;
					const rect = above.getBoundingClientRect();
					const stickyTop = parseFloat(getComputedStyle(above).top);
					// Progress: 0 when card is transitionRange above sticky, 1 when stuck
					const distFromSticky = rect.top - stickyTop;
					const progress = Math.max(
						0,
						Math.min(1, 1 - distFromSticky / transitionRange),
					);
					depth += progress;
				}

				card.style.transform = `scale(${1 - depth * 0.05})`;
			});
		};

		window.addEventListener("scroll", () => requestAnimationFrame(updateCards));
		updateCards();
	});
</script>

<BookingForm locale={locale} />

<style>
	/* ── Track ───────────────────────────────────────────────────────── */

	.cards-track {
		padding-bottom: 2rem;
	}

	/* ── Card ── */

	.card {
		display: grid;
		grid-template-columns: 1fr 1.75fr;
		gap: 3rem;
		align-items: start;
		background-color: var(--color-base);
		border: 1px solid var(--color-overlay);
		padding: calc(3rem + 1vh) 3rem;
		margin-bottom: 2rem;
		box-shadow:
			inset 0 0 100px color-mix(in srgb, var(--color-amber) 6%, transparent),
			0 1px 8px color-mix(in srgb, var(--color-ink) 4%, transparent);
	}

	@media (min-width: 641px) {
		.card {
			position: sticky;
			top: calc(7rem + (var(--i) + 1) * 0.75rem);
			margin-bottom: 7.5vh;
			z-index: calc(var(--i) + 1);
			transform-origin: top center;
		}
	}

	@media (max-width: 640px) {
		.card {
			grid-template-columns: 1fr;
			gap: 1.5rem;
			padding: 2rem 1.5rem;
			border-radius: 12px;
		}

		.card-header {
			display: flex;
			flex-direction: column-reverse;
			gap: 2rem;
		}

		.card-heading {
			text-align: center;
		}

		.card-icon {
			display: flex;
			order: 1;
			justify-content: center;
		}
	}

	/* ── Icon ────────────────────────────────────────────────────────── */

	.card-icon :global(svg) {
		display: block;
		width: 100%;
		max-width: 60%;
		height: auto;
	}

	/* ── Card title ─────────────────────────────────────────────────── */

	.card-title {
		line-height: 1.15;
		color: var(--color-contrast);
	}

	/* ── Card body (set:html descendants) ───────────────────────────── */

	.card-body p {
		margin-bottom: 1rem;
		color: var(--color-ink);
	}

	.card-body p:last-child {
		margin-bottom: 0;
	}

	.card-body strong {
		color: var(--color-contrast);
		font-weight: 600;
	}
</style>
