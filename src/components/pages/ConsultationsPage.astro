---
import { getEntry } from "astro:content";
import { defaultLocale, type Locale, ui } from "../../i18n/site";

import iconNatal from "../../assets/icons/icon-natal.svg?raw";
import iconNatalSolarReturn from "../../assets/icons/icon-natal-solar-return.svg?raw";
import iconHorary from "../../assets/icons/icon-horary.svg?raw";
import iconElective from "../../assets/icons/icon-elective.svg?raw";
import iconSynastry from "../../assets/icons/icon-synastry.svg?raw";
import ConsultationForm from "../ConsultationForm.astro";
import HeroBackground from "../HeroBackground.astro";

const icons: Record<string, string> = {
	natal: iconNatal,
	"natal-solar-return": iconNatalSolarReturn,
	horary: iconHorary,
	elective: iconElective,
	synastry: iconSynastry,
};

const locale = (Astro.currentLocale ?? defaultLocale) as Locale;
const entry = await getEntry("consultations", locale);
const content = entry!.data;
const { bookCta, learnMore } = ui[locale];
---

<HeroBackground src="/images/background-hero-consultations.svg" />

<section
	class="relative w-full flex items-center py-(--spacing-section) min-h-[75vh] overflow-hidden"
>
	<div
		class="relative z-2 w-full max-w-(--width-content) mx-auto px-(--spacing-outer) text-center"
	>
		<h1
			class="text-7xl max-md:text-5xl font-serif tracking-tight leading-none mb-6"
		>
			{content.hero.heading}
		</h1>
		<p class="text-xl md:text-2xl max-w-2xl mx-auto">
			{content.hero.lead}
		</p>
		<div class="flex max-md:flex-col gap-4 items-center justify-center mt-8">
			<a href="#book" class="button">{bookCta}</a>
			<a href="#cards-track" class="button button-alt-dark">{learnMore}</a>
		</div>
	</div>
</section>

<div
	id="cards-track"
	class="cards-track max-w-(--width-wide) mx-auto px-(--spacing-outer)"
>
	{
		content.types.map((type, i) => (
			<article class="card rounded-2xl" style={`--i: ${i}`}>
				<div class="card-header">
					{type.discipline && (
						<p class="text-xs font-semibold tracking-widest uppercase text-secondary mb-2">
							{type.discipline}
						</p>
					)}
					<h2 class="card-title font-serif mb-6">{type.title}</h2>

					<div
						class="w-full card-icon"
						aria-hidden="true"
						set:html={icons[type.id]}
					/>
				</div>

				<div class="card-content">
					<div class="card-body">
						{type.paragraphs.map((p) => (
							<p set:html={p} />
						))}
					</div>{" "}
					<a
						href="#book"
						data-type={type.id}
						class="button button-alt mt-8 inline-block"
					>
						{bookCta}
					</a>
				</div>
			</article>
		))
	}
</div>

<script>
	document
		.querySelectorAll<HTMLAnchorElement>("a[data-type]")
		.forEach((link) => {
			link.addEventListener("click", () => {
				const typeSelect = document.getElementById(
					"cf-type",
				) as HTMLSelectElement | null;
				if (!typeSelect) return;
				typeSelect.value = link.dataset.type!;
				typeSelect.dispatchEvent(new Event("change"));
			});
		});

	document.addEventListener("DOMContentLoaded", () => {
		const cards = document.querySelectorAll(".card");

		const updateCards = () => {
			const viewportHeight = window.innerHeight;
			const topOffset = viewportHeight * 0.005; // 10vh
			console.log(topOffset);

			cards.forEach((card, index) => {
				// We only effect cards that have a next sibling card
				if (index === cards.length - 1) return;

				const nextCard = cards[index + 1];
				const nextRect = nextCard.getBoundingClientRect();

				// Calculate how far the next card is from the bottom of the viewport up to the top offset
				// When nextRect.top is at viewportHeight, progress is 0.
				// When nextRect.top reaches topOffset, progress is 1.

				const dist = nextRect.top - topOffset;
				const range = viewportHeight - topOffset;

				// Progress goes from 0 (next card just entering view) to 1 (next card hits top)
				// Actually, we want scale to decrease as next card goes UP.
				// So when next card is at bottom, scale is 1.
				// When next card is at top, scale is 0.95.

				let progress = 1 - dist / range;

				// Clamp
				if (progress < 0) progress = 0;
				if (progress > 1) progress = 1;

				// Apply effects
				const scale = 1 - progress * 0.1; // Scale down by 10%

				card.style.transform = `scale(${scale})`;
			});

			requestAnimationFrame(updateCards);
		};

		window.addEventListener("scroll", () => {
			requestAnimationFrame(updateCards);
		});

		// Initial run
		updateCards();
	});
</script>

<section id="book" class="bg-overlay py-(--spacing-section) scroll-mt-6">
	<div class="max-w-(--width-wide) mx-auto px-(--spacing-outer)">
		<div class="consultation-grid">
			<div class="consultation-form">
				<ConsultationForm />
			</div>
		</div>
	</div>
</section>

<style>
	/* ── Track ───────────────────────────────────────────────────────── */

	.cards-track {
		padding-bottom: 2rem;
	}

	/* ── Card ── */

	.card {
		display: grid;
		grid-template-columns: 1fr 1.75fr;
		gap: 3rem;
		align-items: start;
		background-color: var(--color-base);
		border: 1px solid var(--color-overlay);
		padding: 3rem;
		margin-bottom: 2rem;
		box-shadow: 0 1px 8px color-mix(in srgb, var(--color-ink) 4%, transparent);
	}

	@media (min-width: 641px) {
		.card {
			position: sticky;
			top: calc(7rem);
			margin-bottom: 10vh;
			z-index: calc(var(--i) + 1);
		}
	}

	@media (max-width: 640px) {
		.card {
			grid-template-columns: 1fr;
			gap: 1.5rem;
			padding: 2rem 1.5rem;
			border-radius: 12px;
		}
	}

	/* ── Icon ────────────────────────────────────────────────────────── */

	.card-icon :global(svg) {
		display: block;
		width: 100%;
		max-width: 10rem;
		height: auto;
	}

	/* ── Card title ─────────────────────────────────────────────────── */

	.card-title {
		font-size: clamp(1.75rem, 4vw, 2.5rem);
		line-height: 1.15;
		color: var(--color-contrast);
	}

	/* ── Card body (set:html descendants) ───────────────────────────── */

	.card-body p {
		margin-bottom: 1rem;
		line-height: 1.7;
		color: var(--color-ink);
	}

	.card-body p:last-child {
		margin-bottom: 0;
	}

	.card-body strong {
		color: var(--color-contrast);
		font-weight: 600;
	}
</style>
