---
import SiteLogo from "./SiteLogo.astro";
import LangSwitcher from "./LangSwitcher.astro";
import {
	defaultLocale,
	navLinks as allNavLinks,
	ui,
	type Locale,
} from "../i18n/site";

interface Props {
	locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;
const navLinks = allNavLinks[locale];
const t = ui[locale];
const currentPath = Astro.url.pathname;
---

<footer class="py-(--spacing-section) bg-contrast text-base">
	<div class="footer-inner w-full mx-auto px-(--spacing-outer)">
		<div class="flex flex-col md:flex-row gap-12 items-stretch mb-10">
			<div
				class="shrink-0 flex flex-col gap-5 md:gap-11 md:w-[20%] justify-between"
			>
				<SiteLogo
					locale={locale}
					instanceId="footer"
					animated={false}
					variant="dark"
					layout="stacked"
				/>
				<div>
					<a
						class="text-base hover:text-secondary font-semibold no-underline hover:no-underline transition-colors duration-150"
						href="mailto:fabio@astrofabio.com">fabio@astrofabio.com</a
					>
				</div>
			</div>
			<nav
				class="flex flex-col grow gap-10 justify-between"
				aria-label="Footer navigation"
			>
				<ul class="list-none m-0 p-0 flex flex-col gap-3">
					{
						navLinks.map(({ href, label }) => (
							<li>
								<a
									href={href}
									class="text-base text-sm tracking-widest uppercase font-semibold no-underline transition-colors duration-150 hover:text-secondary hover:no-underline aria-[current=page]:text-secondary"
									aria-current={currentPath === href ? "page" : undefined}
								>
									{label}
								</a>
							</li>
						))
					}
				</ul>
				<LangSwitcher locale={locale} variant="dark" />
			</nav>
			<div class="w-full md:w-[40%] shrink-0">
				<script async src="https://subscribe-forms.beehiiv.com/embed.js"
				></script><iframe
					src={t.newsletterFormSrc}
					class="beehiiv-embed"
					data-test-id="beehiiv-embed"
					frameborder="0"
					scrolling="no"
					style="width: 100%; height: 353px; margin: 0; border-radius: 0px !important; background-color: transparent; box-shadow: 0 0 #0000;"
				></iframe>
			</div>
		</div>
		<div
			class="border-t border-muted pt-6 flex flex-col md:flex-row sm:justify-between gap-2"
		>
			<span class="text-muted text-sm shrink-0">
				© 2026 Fábio Barbosa ·
				<a
					href={t.termsHref}
					class="text-muted hover:text-accent no-underline transition-colors duration-150"
				>
					{t.termsLabel}</a
				>
			</span>
			<span class="text-muted text-sm">{t.safeSpace}</span>
		</div>
	</div>
</footer>
