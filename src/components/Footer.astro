---
import SiteLogo from "./SiteLogo.astro";
import LangSwitcher from "./LangSwitcher.astro";
import {
	defaultLocale,
	navLinks as allNavLinks,
	ui,
	type Locale,
} from "../i18n/site";

interface Props {
	locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;
const navLinks = allNavLinks[locale];
const t = ui[locale];
const currentPath = Astro.url.pathname;
---

<footer class="py-(--spacing-section) bg-contrast text-base">
	<div class="footer-inner w-full mx-auto px-(--spacing-outer)">
		<div class="flex flex-col md:flex-row gap-12 mb-30 items-start">
			<div class="shrink-0">
				<SiteLogo
					locale={locale}
					instanceId="footer"
					animated={false}
					variant="dark"
					layout="stacked"
				/>
			</div>
			<nav
				class="flex flex-col grow gap-10 justify-between"
				aria-label="Footer navigation"
			>
				<ul class="list-none m-0 p-0 flex flex-col gap-3">
					{
						navLinks.map(({ href, label }) => (
							<li>
								<a
									href={href}
									class="text-base text-sm tracking-widest uppercase font-semibold no-underline transition-colors duration-150 hover:text-accent hover:no-underline aria-[current=page]:text-accent"
									aria-current={currentPath === href ? "page" : undefined}
								>
									{label}
								</a>
							</li>
						))
					}
				</ul>
				<LangSwitcher locale={locale} variant="dark" />
			</nav>
			<div class="w-full md:w-[40%] shrink-0">
				<p class="text-sm font-semibold tracking-widest uppercase mb-3">
					{t.newsletterHeading}
				</p>
				<form
					action="https://buttondown.com/api/emails/embed-subscribe/astrofabio"
					method="post"
					class="flex flex-col"
				>
					<label for="bd-email" class="sr-only">{t.newsletterLabel}</label>
					<div class="flex">
						<input
							type="email"
							name="email"
							id="bd-email"
							placeholder={t.newsletterLabel}
							required
							class="flex-1 min-w-0 pl-3 pr-5 py-2 text-sm font-[inherit] bg-[color-mix(in_srgb,var(--color-ink)_10%,transparent)] border border-[color-mix(in_srgb,var(--color-base)_25%,transparent)] border-r-0 rounded-l-[2em] text-base placeholder:text-[color-mix(in_srgb,var(--color-base)_45%,transparent)] outline-none focus:border-accent transition-colors duration-150"
						/>
						<button type="submit" class="button-alt -ml-6"
							>{t.newsletterSubmit}</button
						>
					</div>
				</form>
			</div>
		</div>
		<div
			class="border-t border-muted pt-6 flex flex-col sm:flex-row sm:justify-between gap-2"
		>
			<span class="text-muted text-sm shrink-0">
				© 2026 Fábio Barbosa ·
				<a
					href={t.termsHref}
					class="text-muted hover:text-ink no-underline transition-colors duration-150"
					>{t.termsLabel}</a
				>
			</span>
			<span class="text-muted text-sm">{t.safeSpace}</span>
		</div>
	</div>
</footer>
