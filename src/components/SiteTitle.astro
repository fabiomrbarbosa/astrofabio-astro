---
import { siteName, siteMeta, defaultLocale, type Locale } from "../i18n/site";

interface Props {
	locale?: Locale;
	variant?: "light" | "dark";
}

const { locale = defaultLocale, variant = "light" } = Astro.props;
const meta = siteMeta[locale];
---

<div class="flex flex-col gap-0.5 uppercase">
	<span
		class:list={[
			"text-sm font-bold leading-4",
			variant === "dark" ? "text-base" : "text-contrast",
		]}>{siteName}</span
	>
	<span
		class:list={[
			"text-sm leading-4 tracking-wider font-features-['ss03']",
			variant === "dark" ? "text-base" : "text-contrast",
		]}>{meta.tagline}</span
	>
</div>
