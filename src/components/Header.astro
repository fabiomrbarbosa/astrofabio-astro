---
import {
	ui,
	defaultLocale,
	siteName,
	siteMeta,
	navLinks as allNavLinks,
	type Locale,
} from "../i18n/site";

interface Props {
	locale?: Locale;
	theme?: "light" | "dark";
}

const { locale = defaultLocale, theme = "light" } = Astro.props;
const t = ui[locale];
const meta = siteMeta[locale];
const navLinks = allNavLinks[locale];
const targetLocale = locale === "en" ? "pt" : "en";
const currentPath = Astro.url.pathname;

// Derive the alternate-locale URL from navLinks instead of a separate map.
// Match the current path in the current locale's nav, then pick the same index
// from the other locale's nav. Fall back to the target locale's root.
const currentNavIndex = (
	allNavLinks[locale] as readonly { href: string }[]
).findIndex((l) => l.href === currentPath);
const switchLangHref =
	currentNavIndex !== -1
		? allNavLinks[targetLocale][currentNavIndex].href
		: t.switchLangHref;
---

<header
	class:list={[
		"flex items-center justify-between py-5",
		{ "header--dark": theme === "dark" },
	]}
>
	<a
		href="/"
		aria-label={t.logoAriaLabel}
		class="site-logo flex items-center gap-4 shrink-0 hover:no-underline"
	>
		<svg
			class="logo w-full max-w-15 max-md:max-w-12 h-auto block"
			role="img"
			aria-labelledby="logo-title"
			viewBox="0 0 560 416"
			xmlns="http://www.w3.org/2000/svg"
		>
			<title id="logo-title">{meta.title}</title>
			<clipPath id="LogoClipPath">
				<path
					d="M427.2,1.1a168,168,0,0,0-65.75,5.46A158.69,158.69,0,0,0,305.79,35.4,143.88,143.88,0,0,0,267.21,83c-5.07,10.22-9.6,20.09-12.77,31q-4.91,17-8.2,34.35c-2.24,11.62-2.89,24.44-4.15,36.21s-1.83,23.56-2.27,35.41-2.25,24.76-3.31,36.72c-1,11.71-2.54,23.39-4.4,35a157.13,157.13,0,0,1-8.17,31.81c-3.56,9.22-6.83,17.27-12.48,25.38C200,365.3,184.12,378.8,165.05,385.35A74.91,74.91,0,0,1,107.74,382a82.11,82.11,0,0,1-13.19-8.07L73,395.48A159,159,0,0,0,112.31,411a167.67,167.67,0,0,0,91.13-3.19,158.93,158.93,0,0,0,39.5-19,155.34,155.34,0,0,0,32-28.48,144.06,144.06,0,0,0,22.78-37.19c6-14.23,10.06-29.23,13.27-44.31,1.66-7.8,3.09-15.65,4.36-23.52.33-2,1.28-8.77,1.28-8.77s8.45,1,12.28,1.12a137.39,137.39,0,0,0,45.85-6,134.14,134.14,0,0,0,38.72-19.26,131.68,131.68,0,0,0,29.42-29.25,47.33,47.33,0,0,0-28.59-7.26,46.74,46.74,0,0,0-24.8,9.22c-3.7,2.81-6.82,6.31-10.26,9.43a109.3,109.3,0,0,1-11.17,8.85,103.59,103.59,0,0,1-49.49,18.16q1-8.91,1.6-17.85c.84-12.13,1.11-24.3,1.58-36.45.32-8.1.93-16.19,1.77-24.26q2.19-21.18,6.42-42.09a109.38,109.38,0,0,1,5.46-19.64,125,125,0,0,1,9.05-17.89c10.7-17.72,26.2-32.81,45.43-40.93a75.17,75.17,0,0,1,58-.57A81.75,81.75,0,0,1,465.7,42l21.61-21.62A161.34,161.34,0,0,0,427.2,1.1Z"
				></path>
				<path
					d="M558.93,122A132.43,132.43,0,0,0,535.06,62.6a143.13,143.13,0,0,0-22.8-24.75L486.5,63.6Q489,67.2,491.26,71c10.79,18.4,16.23,39.72,16.85,61a136,136,0,0,1-13.76,64.32A132.87,132.87,0,0,1,331.56,262c1.33,1.17,2.6,2.4,3.85,3.66a77.52,77.52,0,0,1,19.14,32.09,75.77,75.77,0,0,1,.61,40.93,77.18,77.18,0,0,1-18.7,33.22,81.59,81.59,0,0,1-32.14,20.67,84.35,84.35,0,0,1-41.24,3.54c1.76.84,3.56,1.61,5.37,2.33a89.51,89.51,0,0,0,46.08,5,86.55,86.55,0,0,0,40.15-17.19,76.6,76.6,0,0,0,24.78-33.51,70.05,70.05,0,0,0,1.1-44.91,74.28,74.28,0,0,0-23.14-34.17,163.52,163.52,0,0,0,30.35,6.15,168.81,168.81,0,0,0,54.89-3.19,161.64,161.64,0,0,0,48-19.29A153.42,153.42,0,0,0,516,238.09a141.06,141.06,0,0,0,34.88-50.76A130.51,130.51,0,0,0,558.93,122Z"
				></path>
				<path
					d="M48.81,378.78l25.56-25.55a106.76,106.76,0,0,1-7.48-11.92C56.89,322.8,52.1,301.68,52,280.7a135.43,135.43,0,0,1,14.86-63.28,132.9,132.9,0,0,1,161.73-63.64c-1.34-1.19-2.64-2.43-3.9-3.7a77.34,77.34,0,0,1-19.23-32.53A75.82,75.82,0,0,1,205.23,76a77.16,77.16,0,0,1,19-32.77A81.68,81.68,0,0,1,256.12,23.1,84.21,84.21,0,0,1,297,19.68q-2.7-1.29-5.48-2.38a89.51,89.51,0,0,0-45.91-5,86.51,86.51,0,0,0-40.23,17.21A76.83,76.83,0,0,0,180.66,63a70,70,0,0,0-1.12,45,74.27,74.27,0,0,0,23.15,34.18,161.61,161.61,0,0,0-21.93-5,168.4,168.4,0,0,0-47.61-.69,164.54,164.54,0,0,0-43.62,11.78A157,157,0,0,0,52,170.76a147.12,147.12,0,0,0-29,31.59A135,135,0,0,0,4.61,242.12a129.74,129.74,0,0,0,7.87,89.81,138.29,138.29,0,0,0,24.45,35.65A146.1,146.1,0,0,0,48.81,378.78Z"
				></path>
			</clipPath>
			<g
				class="logo__trace"
				style="-webkit-clip-path: url(#LogoClipPath);"
				clip-path="url(#LogoClipPath)"
				fill="none"
				stroke-linecap="round"
				stroke-linejoin="round"
				stroke-miterlimit="10"
			>
				<path
					d="M264.85,0S212.55-1.69,187,49.28c-23.31,46.53,2.78,81.95,2.78,81.95S87.08,114.73,30.45,188.86,6.13,343.87,47,378.45c89.06,75.18,216.2-.22,228.86-89.14,14.1-99.71-3.33-173.41,54.41-239S517,.75,553.67,100.14c28.85,78.25-43.19,185.15-172.67,191,0,0,22.66,46.84-6.33,89.13s-66.62,35.53-66.62,35.53"
					stroke-width="104"></path>
				<path
					d="m316 243s35.5 4.5 71-22.8c38-29.3 48-41.3 48-41.3"
					stroke-width="44"></path>
			</g>
		</svg>
		<div class="hidden md:flex flex-col leading-tight">
			<span class="text-sm font-semibold text-contrast">{siteName}</span>
			<span class="text-xs text-muted uppercase tracking-widest"
				>{meta.tagline}</span
			>
		</div>
	</a>

	<nav
		class="nav-primary hidden md:flex items-center gap-6"
		aria-label="Primary navigation"
	>
		<ul class="flex items-center gap-6 list-none m-0 p-0">
			{
				navLinks.map(({ href, label }) => (
					<li>
						<a
							href={href}
							class="nav-link text-sm tracking-widest font-semibold"
							aria-current={currentPath === href ? "page" : undefined}
						>
							{label}
						</a>
					</li>
				))
			}
		</ul>
		<div class="lang-switcher">
			<span class="lang-current">{locale.toUpperCase()}</span>
			<span class="lang-sep">/</span>
			<a
				href={switchLangHref}
				aria-label={t.switchLangAriaLabel}
				class="nav-link text-sm"
				data-lang-switch
				data-locale={targetLocale}>{t.switchLang}</a
			>
		</div>
	</nav>

	<button
		id="menu-toggle"
		class="md:hidden border-0 rounded-none bg-transparent p-2 text-contrast cursor-pointer"
		aria-label={t.menuOpen}
		aria-expanded="false"
		aria-controls="mobile-menu"
	>
		<svg
			width="24"
			height="24"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			aria-hidden="true"
		>
			<line x1="3" y1="6" x2="21" y2="6"></line>
			<line x1="3" y1="12" x2="21" y2="12"></line>
			<line x1="3" y1="18" x2="21" y2="18"></line>
		</svg>
	</button>
</header>

<div
	id="mobile-menu"
	class="fixed inset-0 z-50 flex flex-col bg-base translate-x-full transition-transform duration-300 ease-in-out"
	aria-hidden="true"
>
	<div
		class="flex items-center justify-between py-5 px-(--spacing-outer) border-b border-border"
	>
		<a
			href="/"
			aria-label={t.logoAriaLabel}
			class="flex flex-col leading-tight"
		>
			<span class="text-sm font-semibold text-contrast">{siteName}</span>
			<span class="text-xs text-muted uppercase tracking-widest"
				>{meta.tagline}</span
			>
		</a>
		<div class="flex items-center gap-2">
			<div class="lang-switcher">
				<span class="lang-current">{locale.toUpperCase()}</span>
				<span class="lang-sep">/</span>
				<a
					href={switchLangHref}
					aria-label={t.switchLangAriaLabel}
					class="nav-link text-sm"
					data-lang-switch
					data-locale={targetLocale}>{t.switchLang}</a
				>
			</div>
			<button
				id="menu-close"
				class="border-0 rounded-none bg-transparent p-2 text-contrast cursor-pointer"
				aria-label={t.menuClose}
			>
				<svg
					width="24"
					height="24"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					aria-hidden="true"
				>
					<line x1="4" y1="4" x2="20" y2="20"></line>
					<line x1="20" y1="4" x2="4" y2="20"></line>
				</svg>
			</button>
		</div>
	</div>
	<nav class="px-(--spacing-outer) pt-8" aria-label="Mobile navigation">
		<ul class="flex flex-col gap-6 list-none m-0 p-0">
			{
				navLinks.map(({ href, label }) => (
					<li>
						<a
							href={href}
							class="nav-link text-sm font-semibold"
							aria-current={currentPath === href ? "page" : undefined}
						>
							{label}
						</a>
					</li>
				))
			}
		</ul>
	</nav>
</div>

<script>
	const toggle = document.getElementById("menu-toggle") as HTMLButtonElement;
	const close = document.getElementById("menu-close") as HTMLButtonElement;
	const menu = document.getElementById("mobile-menu") as HTMLElement;

	function openMenu() {
		menu.classList.remove("translate-x-full");
		menu.setAttribute("aria-hidden", "false");
		toggle.setAttribute("aria-expanded", "true");
		document.body.style.overflow = "hidden";
	}

	function closeMenu() {
		menu.classList.add("translate-x-full");
		menu.setAttribute("aria-hidden", "true");
		toggle.setAttribute("aria-expanded", "false");
		document.body.style.overflow = "";
	}

	toggle.addEventListener("click", openMenu);
	close.addEventListener("click", closeMenu);

	// Solid header past 50vh
	const header = document.querySelector("header") as HTMLElement;
	function onScroll() {
		header.classList.toggle("header--scrolled", window.scrollY > 120);
	}
	window.addEventListener("scroll", onScroll, { passive: true });
	onScroll();

	// Persist manual language choice so the middleware doesn't override it
	document
		.querySelectorAll<HTMLAnchorElement>("[data-lang-switch]")
		.forEach((el) => {
			el.addEventListener("click", () => {
				const locale = el.dataset.locale;
				if (locale)
					document.cookie = `preferred-locale=${locale};path=/;max-age=${60 * 60 * 24 * 365}`;
			});
		});
</script>

<style>
	/* Always fixed and transparent — bg/shadow added on scroll */
	header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 40;
		padding-left: var(--spacing-outer);
		padding-right: var(--spacing-outer);
		background-color: transparent;
		transition:
			background-color 250ms ease,
			box-shadow 250ms ease;
	}

	/* Dark initial theme: white text over dark page backgrounds */
	header.header--dark {
		--color-contrast: #ffffff;
		--color-ink: #ffffff;
	}

	/* Scrolled: solid white regardless of initial theme — defined after
	   header--dark so it wins the cascade when both classes are present */
	header.header--scrolled {
		background-color: var(--color-base);
		box-shadow:
			0 1px 0 rgba(0, 0, 0, 0.06),
			0 2px 12px rgba(0, 0, 0, 0.06);
		--color-contrast: #141413;
		--color-ink: #30302e;
	}

	/* SVG stroke inherits from the theme token — not expressible as a plain utility */
	.logo {
		stroke: var(--color-contrast);
	}

	/* Language switcher */
	.lang-switcher {
		display: flex;
		align-items: center;
		gap: 0.3em;
		font-size: 0.875rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.lang-current,
	.lang-sep {
		opacity: 0.4;
	}

	/* Nav link: override the global a { color: accent } default */
	.nav-link {
		color: var(--color-ink);
		letter-spacing: 0.06em;
		text-transform: uppercase;
		transition: color 150ms ease;
	}

	header > nav ul {
		position: absolute;
		left: 50%;
		transform: translateX(-50%);
	}

	header .nav-primary > ul .nav-link {
		padding: 0.5rem 1rem;
		background: rgba(255, 255, 255, 0.3);
		border-radius: 2em;
	}

	header .nav-primary > ul .nav-link[aria-current="page"],
	header .nav-primary > ul .nav-link:focus,
	header .nav-primary > ul .nav-link:hover {
		background: white;
		text-decoration: none;
	}

	header.header--scrolled .nav-primary > ul .nav-link[aria-current="page"],
	header.header--scrolled .nav-primary > ul .nav-link:focus,
	header.header--scrolled .nav-primary > ul .nav-link:hover {
		background: var(--color-surface);
	}

	/* ── Logo animation ──────────────────────────────────────── */

	@keyframes drawingin {
		to {
			stroke-dashoffset: 0;
		}
	}

	@keyframes drawingover {
		from {
			stroke-dashoffset: 0;
		}
		25%,
		50% {
			stroke-dashoffset: 1870;
		}
		to {
			stroke-dashoffset: 0;
		}
	}

	:global(.site-logo .logo__trace path) {
		fill: none;
		stroke: var(--color-contrast);
		stroke-dasharray: 1870;
		stroke-dashoffset: 1870;
		transform: translateZ(0);
		animation: drawingin 1.5s cubic-bezier(0.83, 0, 0.17, 1) forwards;
		transition: stroke 0.4s ease;
	}

	:global(.site-logo .logo__trace path + path) {
		animation-delay: 0.75s;
	}

	:global(.site-logo:hover .logo__trace path),
	:global(.site-logo:focus .logo__trace path),
	:global(.site-logo:active .logo__trace path) {
		stroke: var(--color-accent);
	}

	@media (prefers-reduced-motion: reduce) {
		:global(.site-logo .logo__trace path) {
			animation: none;
			stroke-dashoffset: 0;
		}
	}
</style>
