---
interface Props {
	src: string;
}
const { src } = Astro.props;
---

<div class="hero-background" aria-hidden="true">
	<img src={src} alt="" />
</div>

<style>
	.hero-background {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		filter: blur(80px) saturate(200%);
		opacity: 0.2;
		pointer-events: none;
		z-index: -1;
	}

	.hero-background img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
</style>
