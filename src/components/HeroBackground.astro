---
interface Props {
	orb1?: string;
	orb2?: string;
	orb3?: string;
	flip?: boolean;
}

const {
	orb1 = "var(--color-base)",
	orb2 = "var(--color-base)",
	orb3,
	flip = false,
} = Astro.props;
---

<div
	class:list={["hero-background", { "hero-background--flip": flip }]}
	style={`--orb1: ${orb1}; --orb2: ${orb2};${orb3 ? ` --orb3: ${orb3};` : ""}`}
	aria-hidden="true"
>
	{orb3 && <div class="orb-3" />}
</div>

<style>
	.hero-background {
		position: absolute;
		inset: 0;
		overflow-x: clip;
		mask-image: linear-gradient(to bottom, black 50%, transparent 100%);
		pointer-events: none;
		z-index: -1;
	}

	.hero-background::before,
	.hero-background::after {
		content: "";
		position: absolute;
		pointer-events: none;
	}

	.orb-3 {
		position: absolute;
		border-radius: 50%;
		pointer-events: none;
	}

	/* orb1 — top right, orb2 — bottom left (default) */
	.hero-background::before {
		width: 90vw;
		height: 90%;
		background: color-mix(in srgb, var(--orb1) 65%, transparent);
		filter: blur(clamp(60px, 6vw, 140px));
		border-radius: 70% 30% 55% 45% / 50% 65% 35% 50%;
		top: -25%;
		right: -25%;
	}

	.hero-background::after {
		width: 90vw;
		height: 90%;
		background: color-mix(in srgb, var(--orb2) 65%, transparent);
		filter: blur(clamp(60px, 6vw, 140px));
		border-radius: 40% 60% 38% 62% / 62% 44% 56% 38%;
		bottom: -25%;
		left: -25%;
	}

	/* orb3 — centre */
	.orb-3 {
		width: 70vw;
		height: 90%;
		background: color-mix(in srgb, var(--orb3) 55%, transparent);
		filter: blur(clamp(60px, 6vw, 140px));
		top: 50%;
		left: 50%;
		translate: -50% -50%;
		z-index: 10;
	}

	/* flipped: orb1 — bottom left, orb2 — top right (and above, since ::after paints last) */
	.hero-background--flip::before {
		right: unset;
		left: -25%;
	}

	.hero-background--flip::after {
		left: unset;
		right: -25%;
	}
</style>
