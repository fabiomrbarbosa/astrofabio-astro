---
interface Props {
	orb1?: string;
	orb2?: string;
	flip?: boolean;
}

const {
	orb1 = "var(--color-base)",
	orb2 = "var(--color-tertiary)",
	flip = false,
} = Astro.props;
---

<div
	class:list={["hero-background", { "hero-background--flip": flip }]}
	style={`--orb1: ${orb1}; --orb2: ${orb2};`}
	aria-hidden="true"
>
</div>

<style>
	.hero-background {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: -1;
	}

	.hero-background::before,
	.hero-background::after {
		content: "";
		position: absolute;
		border-radius: 50%;
		pointer-events: none;
	}

	/* orb1 — top right, orb2 — bottom left (default) */
	.hero-background::before {
		width: 90vw;
		height: 90vh;
		background: color-mix(in srgb, var(--orb1) 25%, transparent);
		filter: blur(90px) saturate(150%);
		top: -25%;
		right: -25%;
	}

	.hero-background::after {
		width: 90vw;
		height: 90vh;
		background: color-mix(in srgb, var(--orb2) 25%, transparent);
		filter: blur(90px);
		bottom: -25%;
		left: -25%;
	}

	/* flipped: orb1 — bottom left, orb2 — top right (and above, since ::after paints last) */
	.hero-background--flip::before {
		right: unset;
		left: -25%;
	}

	.hero-background--flip::after {
		left: unset;
		right: -25%;
	}
</style>
