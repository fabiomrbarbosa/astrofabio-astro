---
import "../styles/global.css";
import Header from "../components/Header.astro";
import { defaultLocale, htmlLang, ui, type Locale } from "../i18n";

interface Props {
	title?: string;
	transparentHeader?: boolean;
}

const { title, transparentHeader = false } = Astro.props;
const locale = (Astro.currentLocale ?? defaultLocale) as Locale;
const t = ui[locale];
---

<!doctype html>
<html lang={htmlLang[locale]}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
		<link rel="icon" href="/images/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title ? `${title} | Fábio Barbosa` : t.siteTitle}</title>
	</head>
	<body>
		<Header locale={locale} transparent={transparentHeader} />
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
