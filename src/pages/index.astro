---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
---

<Layout>
	<Header />
	<section
		class="relative -mx-(--spacing-outer) min-h-screen flex items-center py-(--spacing-section)"
	>
		<span aria-hidden="true" class="absolute inset-0 bg-contrast"></span>
		<div
			class="relative z-10 w-full max-w-(--width-wide) mx-auto px-(--spacing-outer) text-white"
		>
			<h1 class="text-6xl font-serif leading-tight">
				Olá.<br />Chamo-me Fábio Barbosa.
			</h1>
			<p class="text-3xl leading-tight">
				Ofereço consultas, ferramentas e escrita ao serviço de uma astrologia
				rigorosa e humana.
			</p>
			<div class="flex justify-start mt-6">
				<a
					href="#"
					class="border-2 border-accent text-accent rounded-[2em] px-4 py-1 uppercase tracking-widest font-semibold hover:bg-accent hover:text-contrast hover:no-underline transition-colors duration-150"
					>Marcar consulta</a
				>
			</div>
		</div>
	</section>
</Layout>
